{
  "cmd/mkrk/*.go": {
    "type": "main"
  },
  "internal/*/*_test.go": {
    "type": "test",
    "alternate": "internal/{}.go"
  },
  "internal/*/*.go": {
    "type": "source",
    "alternate": "internal/{}_test.go"
  },
  "internal/cli/*.go": {
    "type": "command"
  },
  "internal/db/*.go": {
    "type": "db"
  },
  "internal/models/*.go": {
    "type": "model"
  },
  "internal/context/*.go": {
    "type": "context"
  },
  "internal/integrity/*.go": {
    "type": "integrity"
  },
  "internal/generator/*.go": {
    "type": "generator"
  },
  "internal/materialize/*.go": {
    "type": "materialize"
  },
  "internal/evaluate/*.go": {
    "type": "evaluate"
  },
  "internal/reference/*.go": {
    "type": "reference"
  },
  "internal/resolve/*.go": {
    "type": "resolve"
  },
  "internal/walk/*.go": {
    "type": "walk"
  },
  "tests/*.go": {
    "type": "integration"
  },
  "go.mod": {
    "type": "gomod"
  },
  "README.md": {
    "type": "readme"
  }
}
